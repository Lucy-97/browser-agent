# Browser Agent 生产 Compose 非敏感配置模板。
# 复制为 .env 后填写；真实密钥只放入 secrets/*.txt，不要写入本文件。

COMPOSE_PROJECT_NAME=browser_agent_production
IMAGE_REPOSITORY_PREFIX=ghcr.io/lucy-97/browser-agent
# 必须使用已发布的完整 commit SHA，禁止 latest/main。
IMAGE_TAG=
MYSQL_CLIENT_IMAGE=mysql:8.0.43

PUBLIC_WEB_BASE_URL=https://app.example.com
WEB_BIND_HOST=127.0.0.1
WEB_BIND_PORT=3000

DB_HOST=mysql.example.internal
DB_PORT=3306
DB_USER=browser_agent
DB_NAME=browser_agent
DB_SSL_MODE=VERIFY_IDENTITY
MYSQL_MAX_OPEN_CONNS=20
MYSQL_MAX_IDLE_CONNS=10

REDIS_ADDR=redis.example.internal:6379
REDIS_HOST=redis.example.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_REQUIRED=true
REDIS_TLS_ENABLED=true
REDIS_TLS_SERVER_NAME=redis.example.internal

JWT_ACCESS_TOKEN_EXP_SEC=3600
JWT_REFRESH_TOKEN_EXP_DAYS=30
AUTH_COOKIE_NAME=browser_agent_access

JWT_SECRET_FILE=./secrets/jwt_secret.txt
INTERNAL_API_SECRET_FILE=./secrets/internal_api_secret.txt
MYSQL_DSN_FILE=./secrets/mysql_dsn.txt
DB_PASSWORD_FILE=./secrets/db_password.txt
REDIS_PASSWORD_FILE=./secrets/redis_password.txt
