# BrowserAgent 本地开发环境配置示例。复制为 .env 后按需修改。

# ─── App ───
APP_ENV=dev

# ─── Ports ───
GATEWAY_PORT=8080
API_PORT=8001
AI_ENGINE_PORT=8002

# ─── Service URLs（gateway 转发用）───
API_SERVICE_URL=http://localhost:8001
AI_ENGINE_SERVICE_URL=http://localhost:8002
API_BASE_URL=http://localhost:8001

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000,http://localhost:5174

# ─── JWT（务必随机生成，至少 32 字节）───
JWT_SECRET=replace-me-with-a-random-32-byte-secret
JWT_ACCESS_TOKEN_EXP_SEC=3600
JWT_REFRESH_TOKEN_EXP_DAYS=30

# ─── Internal service-to-service auth ───
# gateway 注入此头给 api/ai-engine；下游用 X-Internal-Secret 校验。空字符串 = dev 模式跳过。
INTERNAL_API_SECRET=

# ─── MySQL ───
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=browser-agent

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── 动态配置加密主密钥（AES-256-GCM）───
# 留空可启动，但 system_config 中的加密凭据将无法解密。
CONFIG_MASTER_KEY=
