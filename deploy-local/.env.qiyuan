# ==========================================
# 隔离环境配置: QIYUAN (AI 4 Science)
# ==========================================
COMPOSE_PROJECT_NAME=qiyuan

# 1. 宿主机端口偏移
# ------------------
API_ADDR=:28001
WEB_PORT=23001
ADMIN_PORT=25174
# 2. 基础设施端口偏移 (对应 docker-compose-infra.yaml)
# ------------------
MYSQL_PORT=23307
REDIS_PORT=26380
# 3. 本地存储配置
# ------------------
ARTIFACT_DIR=deploy-local/artifacts

# 4. 安全鉴权配置
# ------------------
INTERNAL_SECRET=local-dev-internal-secret-qiyuan
ADMIN_API_TOKEN=
WEB_API_TOKEN=

# 5. 依赖服务连接 (自动引用上述端口)
# ------------------
MYSQL_DSN="qiyuan:qiyuan@tcp(127.0.0.1:${MYSQL_PORT})/qiyuan?parseTime=true&charset=utf8mb4&loc=Local"
MYSQL_MAX_OPEN_CONNS=10
MYSQL_MAX_IDLE_CONNS=5

REDIS_ADDR=127.0.0.1:${REDIS_PORT}
REDIS_PASSWORD=
REDIS_DB=0
# 6. 微服务内部互调地址
# ------------------
ADMIN_API_BASE_URL=http://127.0.0.1:28001
WORKER_SERVER_URL=http://127.0.0.1:28001
WORKER_DISPLAY_NAME="QIYUAN Local Worker"
GO_API_BASE_URL=http://127.0.0.1:28001

POLL_INTERVAL_SECONDS=5
POLL_BATCH_SIZE=5

# 7. 外部 AI/解析服务配置
# ------------------
LLM_PROVIDER=gemini
LLM_BASE_URL=
LLM_API_KEY=AIzaSyCu1d2m5UP7tM7tetLshOdpNF5EWFy_RdM
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=120
