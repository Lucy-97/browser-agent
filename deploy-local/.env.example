# ==========================================
# 本地隔离环境配置模板 (.env.example)
# ==========================================
# 复制此文件为 `.env`，或使用 `QIYUAN_ENV` 变量加载指定文件，
# 例如 `.env.qiyuan` 或 `.env.browser-agent`。

# 核心：通过修改 Project Name 实现 Docker 容器与数据卷隔离
COMPOSE_PROJECT_NAME=qiyuan

# 1. 宿主机服务端口
# ------------------
API_ADDR=:28001
WEB_PORT=23001
ADMIN_PORT=25174
# 2. 基础设施映射端口 (MySQL, Redis)
# 如果多开分支，请确保下述端口偏移（如 24307, 25307 等）以免冲突
# ------------------
MYSQL_PORT=23307
REDIS_PORT=26380
# 3. 本地存储配置
# ------------------
ARTIFACT_DIR=deploy-local/artifacts

# 4. 安全鉴权配置
# ------------------
INTERNAL_SECRET=local-dev-internal-secret
ADMIN_API_TOKEN=
WEB_API_TOKEN=

# 5. 依赖服务连接 (自动引用上述端口)
# ------------------
MYSQL_DSN="qiyuan:qiyuan@tcp(127.0.0.1:${MYSQL_PORT})/qiyuan?parseTime=true&charset=utf8mb4&loc=Local"
MYSQL_MAX_OPEN_CONNS=10
MYSQL_MAX_IDLE_CONNS=5

REDIS_ADDR=127.0.0.1:${REDIS_PORT}
REDIS_PASSWORD=
REDIS_DB=0
# 6. 微服务内部互调地址
# ------------------
ADMIN_API_BASE_URL=http://127.0.0.1:28001
WORKER_SERVER_URL=http://127.0.0.1:28001
WORKER_DISPLAY_NAME="QIYUAN Local Worker"
GO_API_BASE_URL=http://127.0.0.1:28001

POLL_INTERVAL_SECONDS=5
POLL_BATCH_SIZE=5

# 7. 外部 AI/解析服务配置
# ------------------
LLM_PROVIDER=disabled
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120
