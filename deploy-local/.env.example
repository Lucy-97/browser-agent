# ==========================================
# Browser Agent 本地环境配置模板 (.env.example)
# ==========================================
# 推荐复制为 `.env.browser-agent`；也可复制为 `.env`。
# 如需临时加载其他文件，可设置 BROWSER_AGENT_ENV_FILE。
COMPOSE_PROJECT_NAME=browser_agent
BROWSER_AGENT_ENV=browser-agent

# 1. 宿主机服务端口
# ------------------
API_ADDR=:29001
GATEWAY_PORT=29000
WEB_PORT=24001
ADMIN_PORT=26174
# 2. 基础设施映射端口 (MySQL, Redis)
# ------------------
MYSQL_PORT=24307
REDIS_PORT=27380
# 3. 本地存储配置
# ------------------
ARTIFACT_DIR=deploy-local/artifacts

# 4. 安全鉴权配置
# ------------------
INTERNAL_SECRET=local-dev-internal-secret
INTERNAL_API_SECRET=${INTERNAL_SECRET}
ADMIN_API_TOKEN=
WEB_API_TOKEN=
JWT_SECRET=replace-with-a-random-local-development-secret
JWT_ACCESS_TOKEN_EXP_SEC=3600
AUTH_COOKIE_NAME=browser_agent_access
AUTH_COOKIE_SECURE=false
ALLOW_PUBLIC_REGISTRATION=true
DEFAULT_TENANT_ID=tenant_local
DEFAULT_USER_ID=user_local
REQUIRE_TENANT_IDENTITY=false
REQUIRE_MEMBERSHIP_VALIDATION=true
REQUIRE_WORKER_PAIRING_APPROVAL=true

# 5. 依赖服务连接 (自动引用上述端口)
# ------------------
MYSQL_DSN="qiyuan:qiyuan@tcp(127.0.0.1:${MYSQL_PORT})/qiyuan?parseTime=true&charset=utf8mb4&loc=Local"
MYSQL_MAX_OPEN_CONNS=10
MYSQL_MAX_IDLE_CONNS=5

REDIS_ADDR=127.0.0.1:${REDIS_PORT}
REDIS_PASSWORD=
REDIS_DB=0
# 6. 微服务内部互调地址
# ------------------
ADMIN_API_BASE_URL=http://127.0.0.1:29001
API_SERVICE_URL=http://127.0.0.1:29001
WORKER_SERVER_URL=http://127.0.0.1:29001
WORKER_DISPLAY_NAME="Browser Agent Local Worker"
BROWSER_AGENT_WORKER_ENABLED_PRODUCTS=core,browser_agent,social,weixin
GO_API_BASE_URL=http://127.0.0.1:29000
PUBLIC_WEB_BASE_URL=http://localhost:24001
CORS_ORIGINS=http://localhost:24001,http://127.0.0.1:24001

POLL_INTERVAL_SECONDS=5
POLL_BATCH_SIZE=5

# 7. 外部 AI/解析服务配置
# ------------------
LLM_PROVIDER=disabled
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120
